{
  "name": "nxtcm-components",
  "version": "0.0.1",
  "description": "Shared React component library for Red Hat Insights ACM and OCM projects built with PatternFly",
  "main": "dist/index.umd.js",
  "module": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/RedHatInsights/nxtcm-components.git"
  },
  "keywords": [
    "react",
    "components",
    "patternfly",
    "acm",
    "ocm",
    "red-hat",
    "insights",
    "typescript",
    "ui"
  ],
  "author": "Red Hat",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/RedHatInsights/nxtcm-components/issues"
  },
  "homepage": "https://github.com/RedHatInsights/nxtcm-components#readme",
  "peerDependencies": {
    "@patternfly/react-core": "^6.0.0",
    "js-yaml": "^4.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "semver": "^7.7.4",
    "yaml": "^2.8.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "prettier:check": "prettier --check '{src,cypress,scripts}/**/*.{js,ts,mjs,jsx,tsx}'",
    "prettier:fix": "prettier --write '{src,cypress,scripts}/**/*.{js,ts,mjs,jsx,tsx}'",
    "test": "jest",
    "test:all": "npm run test && npm run test:ct",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "rm -rf .nyc_output && COVERAGE=true playwright test && nyc report",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:ct:coverage": "rm -rf .nyc_output && playwright test -c playwright-ct.config.ts --timeout 60000 && nyc report",
    "coverage:report": "nyc report",
    "test:ct:watch": "playwright test -c playwright-ct.config.ts --ui",
    "test:ct:debug": "playwright test -c playwright-ct.config.ts --debug",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-component-groups": "^6.3.0",
    "@patternfly/react-icons": "^6.3.1",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/widgetized-dashboard": "^1.0.0-prerelease.1",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "cidr-tools": "^11.0.3",
    "handlebars": "^4.7.8",
    "ip-cidr": "^3.1.0",
    "js-yaml": "^4.1.0",
    "progress": "^2.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@babel/core": "^7.22.10",
    "@babel/preset-env": "^7.22.10",
    "@babel/preset-react": "^7.22.5",
    "@babel/preset-typescript": "^7.22.5",
    "@patternfly/react-charts": "^8.4.0",
    "@patternfly/react-core": "^6.0.0",
    "@playwright/experimental-ct-react": "^1.56.1",
    "@playwright/test": "^1.56.1",
    "@react-hook/resize-observer": "^2.0.2",
    "@storybook/addon-docs": "^9.1.10",
    "@storybook/react": "^9.1.15",
    "@storybook/react-vite": "^9.1.10",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.9.1",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.2.7",
    "@types/set-value": "^4.0.3",
    "@types/victory": "^33.1.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "babel-jest": "^29.7.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "get-value": "^4.0.1",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "klona": "^2.0.6",
    "lint-staged": "^16.2.6",
    "nyc": "^18.0.0",
    "prettier": "^3.6.2",
    "pretty-html-log": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.93.2",
    "set-value": "^4.1.0",
    "storybook": "^9.1.10",
    "typescript": "^5.2.2",
    "victory-area": "^37.3.6",
    "victory-axis": "^37.3.6",
    "victory-bar": "^37.3.6",
    "victory-box-plot": "^37.3.6",
    "victory-chart": "^37.3.6",
    "victory-core": "^37.3.6",
    "victory-create-container": "^37.3.6",
    "victory-cursor-container": "^37.3.6",
    "victory-group": "^37.3.6",
    "victory-legend": "^37.3.6",
    "victory-line": "^37.3.6",
    "victory-pie": "^37.3.6",
    "victory-scatter": "^37.3.6",
    "victory-stack": "^37.3.6",
    "victory-tooltip": "^37.3.6",
    "victory-voronoi-container": "^37.3.6",
    "victory-zoom-container": "^37.3.6",
    "vite": "^5.4.0",
    "vite-plugin-istanbul": "^8.0.0",
    "yaml": "^2.8.1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint",
      "prettier --write"
    ],
    "*.{js,jsx,mjs}": [
      "prettier --write"
    ]
  }
}
